{
  "mcpServers": {
    "claude-context": {
      "command": "npx",
      "args": [
        "-y",
        "@zilliz/claude-context-mcp@latest"
      ],
      "env": {
        "EMBEDDING_PROVIDER": "Ollama",
        "EMBEDDING_MODEL": "nomic-embed-text",
        "OLLAMA_HOST": "http://localhost:11434",
        "MILVUS_TOKEN": "${user_config.milvus_token}"
      }
    }
  }
}
